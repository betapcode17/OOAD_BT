## Example DB config for local development
# Copy this to src/main/resources/db.properties and fill real credentials.

db.driver=com.mysql.cj.jdbc.Driver
db.url=jdbc:mysql://localhost:3306/calendar_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
db.username=root
db.password=YOUR_PASSWORD_HERE

# Optional: set db.reset=true to drop and recreate schema on startup (DANGEROUS)
# db.reset=true
